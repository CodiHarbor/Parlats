# Database
DATABASE_URL=postgres://parlats:parlats_dev@localhost:5433/parlats

# Server
PORT=3100
NODE_ENV=development
APP_URL=http://localhost:3100

# OAuth — Google (optional, email+password auth works without this)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3100/auth/google/callback

# Session
SESSION_SECRET=change-me-to-a-random-string

# Email — Resend (optional, needed for invitations/notifications/password resets)
# RESEND_API_KEY=

# Observability — PostHog (optional, enables event tracking and error capture)
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com  # use https://eu.i.posthog.com for EU

# Stripe billing (optional — omit for self-hosted, all billing UI hidden)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
