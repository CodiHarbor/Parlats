{
  "name": "@parlats/cli",
  "version": "1.0.2",
  "description": "CLI for syncing translations with Parlats",
  "bin": {
    "parlats": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun src/index.ts",
    "test": "bun test"
  },
  "keywords": [
    "parlats",
    "i18n",
    "translation",
    "cli",
    "next-intl",
    "i18next"
  ],
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.3.10"
  }
}
