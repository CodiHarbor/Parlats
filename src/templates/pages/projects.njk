{% extends "base.njk" %}

{% from "macros/ui.njk" import empty_state %}

{% block title %}Projects — Parlats{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold mb-1">{{ t("projects.title") }}</h1>
    <p class="text-text-muted text-sm">{{ t("projects.subtitle") }}</p>
  </div>
  {% if projects.length > 0 and (ctx.org.role == 'owner' or ctx.org.role == 'admin') %}
  <a href="/projects/new"
     class="px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded font-medium text-sm no-underline">
    {{ t("projects.new_project") }}
  </a>
  {% endif %}
</div>

{% if projects.length > 0 %}
<div class="overflow-x-auto rounded-lg border border-border">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-border bg-surface-card">
        <th scope="col" class="text-left px-4 py-3 font-medium text-text-secondary">{{ t("projects.table_name") }}</th>
        <th scope="col" class="text-left px-4 py-3 font-medium text-text-secondary">{{ t("projects.table_default_language") }}</th>
        <th scope="col" class="text-left px-4 py-3 font-medium text-text-secondary">{{ t("projects.table_languages") }}</th>
        <th scope="col" class="text-left px-4 py-3 font-medium text-text-secondary">{{ t("projects.table_keys") }}</th>
        <th scope="col" class="text-left px-4 py-3 font-medium text-text-secondary">{{ t("projects.table_created") }}</th>
      </tr>
    </thead>
    <tbody>
      {% for project in projects %}
      <tr class="border-b border-border last:border-0 hover:bg-surface-hover transition-colors">
        <td class="px-4 py-3">
          <a href="/projects/{{ project.id }}" class="font-medium text-text-primary hover:text-primary no-underline">{{ project.name }}</a>
          {% if project.description %}<br><span class="text-xs text-text-muted">{{ project.description }}</span>{% endif %}
        </td>
        <td class="px-4 py-3"><code class="text-xs bg-surface px-1.5 py-0.5 rounded text-text-secondary">{{ project.default_language }}</code></td>
        <td class="px-4 py-3 text-text-secondary">{{ project.language_count }}</td>
        <td class="px-4 py-3 text-text-secondary">{{ project.key_count }}</td>
        <td class="px-4 py-3 text-xs text-text-muted">{{ project.created_at | date }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% if totalPages > 1 %}
<nav class="flex gap-1 items-center justify-center mt-6" aria-label="Projects pagination">
  {% if page > 1 %}
  <a href="/projects?page={{ page - 1 }}"
     class="px-2 py-1 rounded text-sm no-underline text-text-secondary hover:bg-surface-hover min-w-[44px] min-h-[44px] flex items-center justify-center"
     aria-label="Previous page">&lsaquo;</a>
  {% else %}
  <span class="px-2 py-1 rounded text-sm text-text-muted/30 min-w-[44px] min-h-[44px] flex items-center justify-center">&lsaquo;</span>
  {% endif %}

  {% for p in pageWindow %}
    {% if p === null %}
      <span class="px-2 py-1 text-sm text-text-muted">…</span>
    {% else %}
      <a href="/projects?page={{ p }}"
         class="px-3 py-1 rounded text-sm no-underline min-w-[44px] min-h-[44px] flex items-center justify-center
                {% if p == page %}bg-primary text-white font-semibold{% else %}text-text-secondary hover:bg-surface-hover{% endif %}">
        {{ p }}
      </a>
    {% endif %}
  {% endfor %}

  {% if page < totalPages %}
  <a href="/projects?page={{ page + 1 }}"
     class="px-2 py-1 rounded text-sm no-underline text-text-secondary hover:bg-surface-hover min-w-[44px] min-h-[44px] flex items-center justify-center"
     aria-label="Next page">&rsaquo;</a>
  {% else %}
  <span class="px-2 py-1 rounded text-sm text-text-muted/30 min-w-[44px] min-h-[44px] flex items-center justify-center">&rsaquo;</span>
  {% endif %}
</nav>
{% endif %}
{% else %}
{{ empty_state(
  t("projects.no_projects_title"),
  t("projects.no_projects_message"),
  "/projects/new",
  t("projects.create_project")
) }}
{% endif %}
{% endblock %}
