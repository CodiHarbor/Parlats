{# ========== QUICK START ========== #}
<section id="quickstart" class="bg-surface-card/30 border-y border-border py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <h2 class="text-3xl font-bold text-center mb-4">Running in 60 seconds</h2>
    <p class="text-text-secondary text-center max-w-xl mx-auto mb-10">Three commands. That's it.</p>

    <div class="bg-surface-card border border-border rounded-xl overflow-hidden">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-border bg-surface-card">
        <span class="w-3 h-3 rounded-full bg-danger/60"></span>
        <span class="w-3 h-3 rounded-full bg-warning/60"></span>
        <span class="w-3 h-3 rounded-full bg-success/60"></span>
        <span class="ml-2 text-xs text-text-muted font-mono">terminal</span>
      </div>
      <pre class="p-6 text-sm font-mono text-text-primary overflow-x-auto"><code><span class="text-text-muted">$</span> git clone https://github.com/CodiHarbor/Parlats.git &amp;&amp; cd parlats
