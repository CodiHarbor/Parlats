{% extends "base.njk" %}

{% from "macros/forms.njk" import field, submit %}
{% from "macros/ui.njk" import breadcrumbs %}

{% block title %}Edit {{ project.name }} — Parlats{% endblock %}

{% block content %}
{{ breadcrumbs([
  { label: t("nav.projects"), url: "/projects" },
  { label: project.name, url: "/projects/" + project.id },
  { label: t("common.edit") }
]) }}

<div class="max-w-lg">
  <div class="mb-6">
    <h1 class="text-2xl font-bold mb-1">{{ t("projects.edit_title") }}</h1>
    <p class="text-text-muted text-sm">{{ t("projects.edit_subtitle") }}</p>
  </div>

  <form method="post" action="/projects/{{ project.id }}/edit" class="space-y-4">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    {{ field("name", t("projects.field_name"), value=values.name,
       error=errors.name._errors[0] if errors and errors.name,
       required=true) }}

    {{ field("description", t("projects.field_description"), value=values.description) }}

    <div class="mb-4">
      <label for="default_language" class="block text-sm font-medium text-text-secondary mb-1">{{ t("projects.field_default_language") }}</label>
      <select id="default_language" name="default_language"
        class="w-full bg-surface border border-border rounded px-3 py-2 text-text-primary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary">
        {% for lang in languages %}
        <option value="{{ lang.language_code }}" {% if values.default_language == lang.language_code %}selected{% endif %}>{{ lang.label }} ({{ lang.language_code }})</option>
        {% endfor %}
      </select>
    </div>

    <div class="mb-4">
      <label for="default_namespace_id" class="block text-sm font-medium text-text-secondary mb-1">Default Namespace</label>
      <select id="default_namespace_id" name="default_namespace_id"
        class="w-full bg-surface border border-border rounded px-3 py-2 text-text-primary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary">
        <option value="">None (use first)</option>
        {% for ns in namespaces %}
        <option value="{{ ns.id }}" {% if values.default_namespace_id == ns.id %}selected{% endif %}>{{ ns.name }}</option>
        {% endfor %}
      </select>
    </div>

    <div class="mb-4">
      <label for="interpolation_format" class="block text-sm font-medium text-text-secondary mb-1">{{ t("projects.field_interpolation_format") }}</label>
      <select id="interpolation_format" name="interpolation_format"
        class="w-full bg-surface border border-border rounded px-3 py-2 text-text-primary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary">
        <option value="auto" {% if values.interpolation_format == 'auto' %}selected{% endif %}>{{ t("projects.option_auto_detect") }}</option>
        <option value="i18next" {% if values.interpolation_format == 'i18next' %}selected{% endif %}>i18next (&#123;&#123;name&#125;&#125;)</option>
        <option value="icu" {% if values.interpolation_format == 'icu' %}selected{% endif %}>ICU MessageFormat ({name})</option>
      </select>
      <p class="text-text-muted text-xs mt-1">{{ t("projects.interpolation_help") }}</p>
    </div>

    <div class="flex gap-2">
      {{ submit(t("projects.save_changes")) }}
      <a href="/projects/{{ project.id }}"
         class="px-4 py-2 bg-surface-card border border-border hover:bg-surface-hover text-text-primary rounded font-medium text-sm no-underline">{{ t("common.cancel") }}</a>
    </div>
  </form>
</div>
{% endblock %}
