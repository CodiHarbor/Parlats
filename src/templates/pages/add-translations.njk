{% extends "base.njk" %}

{% from "macros/ui.njk" import breadcrumbs %}

{% block title %}Add Translations — {{ project.name }} — Parlats{% endblock %}

{% block content %}
{{ breadcrumbs([
  { label: "Projects", url: "/projects" },
  { label: project.name, url: "/projects/" + project.id },
  { label: "Add Translations" }
]) }}

<div class="flex items-center justify-between mb-6 flex-wrap gap-3">
  <h1 class="text-2xl font-bold">Add Translations</h1>
  <div class="flex items-center gap-3">
    <label for="ns-select" class="text-sm text-text-secondary">Namespace:</label>
    <select id="ns-select"
      class="bg-surface border border-border rounded px-3 py-1.5 text-sm text-text-primary focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary">
      {% for ns in namespaces %}
      <option value="{{ ns.id }}" {% if ns.id == activeNsId %}selected{% endif %}>{{ ns.name }}</option>
      {% endfor %}
    </select>
  </div>
</div>

{# Status messages #}
<div id="status-area" class="hidden mb-4 p-3 rounded-lg text-sm flex items-center justify-between"></div>

{# Scrollable table #}
<div class="overflow-x-auto border border-border rounded-lg mb-4">
  <table class="w-full text-sm" id="translations-table">
    <thead>
      <tr class="bg-surface-card border-b border-border">
        <th class="px-3 py-2 text-left text-text-secondary font-medium w-8 text-center">#</th>
        <th class="px-3 py-2 text-left text-text-secondary font-medium min-w-[240px]">Key</th>
        {% for lang in languages %}
        <th class="px-3 py-2 text-left text-text-secondary font-medium min-w-[200px]">{{ lang.language_code }}</th>
        {% endfor %}
        <th class="px-3 py-2 text-center text-text-secondary font-medium w-12"></th>
      </tr>
    </thead>
    <tbody id="table-body">
    </tbody>
  </table>
</div>

{# Action buttons #}
<div class="flex items-center gap-3 flex-wrap">
  <button type="button" id="save-btn" disabled
    class="px-5 py-2 bg-primary hover:bg-primary-hover text-white rounded font-medium text-sm cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
    onclick="saveTranslations()">Save Translations</button>
  <button type="button"
    class="px-4 py-2 bg-surface border border-border hover:bg-surface-hover text-text-primary rounded font-medium text-sm cursor-pointer"
    onclick="addRows(10)">Add 10 more rows</button>
  <button type="button"
    class="px-4 py-2 bg-surface border border-border hover:bg-surface-hover text-text-secondary rounded font-medium text-sm cursor-pointer"
    onclick="clearAll()">Clear all</button>
  <a href="/projects/{{ project.id }}/editor?namespace={{ activeNsId }}"
     class="px-4 py-2 text-sm text-text-secondary hover:text-text-primary no-underline">Cancel</a>
</div>

<script nonce="{{ nonce }}">
var PROJECT_ID = '{{ project.id }}';
var LANGUAGES = [{% for lang in languages %}'{{ lang.language_code }}'{% if not loop.last %}, {% endif %}{% endfor %}];
var STORAGE_KEY = 'parlats-add-' + PROJECT_ID;
var rowCounter = 0;

function getNamespaceId() {
  return document.getElementById('ns-select').value;
}

function createRow() {
  rowCounter++;
  var tr = document.createElement('tr');
  tr.className = 'border-b border-border hover:bg-surface-card/50';
  tr.dataset.row = rowCounter;

  // Row number
  var numTd = document.createElement('td');
  numTd.className = 'px-3 py-1.5 text-center text-text-muted text-xs';
  numTd.textContent = rowCounter;
  tr.appendChild(numTd);

  // Key cell
  var keyTd = document.createElement('td');
  keyTd.className = 'px-1.5 py-1';
  var keyWrapper = document.createElement('div');
  var keyInput = document.createElement('input');
  keyInput.type = 'text';
  keyInput.className = 'key-input w-full bg-transparent border border-transparent hover:border-border focus:border-primary rounded px-1.5 py-1 text-sm text-text-primary font-mono focus:outline-none';
  keyInput.placeholder = 'translation.key';
  keyInput.addEventListener('input', onInput);
  keyInput.addEventListener('blur', onKeyBlur);
  keyWrapper.appendChild(keyInput);
  var keyError = document.createElement('div');
  keyError.className = 'key-error';
  keyWrapper.appendChild(keyError);
  keyTd.appendChild(keyWrapper);
  tr.appendChild(keyTd);

  // Language cells
  for (var i = 0; i < LANGUAGES.length; i++) {
    var langTd = document.createElement('td');
    langTd.className = 'px-1.5 py-1';
    var langInput = document.createElement('input');
    langInput.type = 'text';
    langInput.className = 'lang-' + LANGUAGES[i].replace(/-/g, '_') + ' w-full bg-transparent border border-transparent hover:border-border focus:border-primary rounded px-1.5 py-1 text-sm text-text-primary focus:outline-none';
    langInput.placeholder = LANGUAGES[i];
    langInput.dataset.lang = LANGUAGES[i];
    langInput.addEventListener('input', onInput);
    langTd.appendChild(langInput);
    tr.appendChild(langTd);
  }

  // Delete button
  var delTd = document.createElement('td');
  delTd.className = 'px-1.5 py-1 text-center';
  var delBtn = document.createElement('button');
  delBtn.type = 'button';
  delBtn.className = 'text-text-muted hover:text-red-400 bg-transparent border-0 cursor-pointer p-1';
  delBtn.innerHTML = '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18L18 6M6 6l12 12"/></svg>';
  delBtn.addEventListener('click', function() {
    tr.remove();
    renumberRows();
    saveToStorage();
    updateSaveButton();
  });
  delTd.appendChild(delBtn);
  tr.appendChild(delTd);

  return tr;
}

function addRows(n) {
  var body = document.getElementById('table-body');
  for (var i = 0; i < n; i++) {
    body.appendChild(createRow());
  }
}

function renumberRows() {
  var rows = document.getElementById('table-body').querySelectorAll('tr');
  rowCounter = 0;
  for (var i = 0; i < rows.length; i++) {
    rowCounter++;
    rows[i].dataset.row = rowCounter;
    rows[i].querySelector('td').textContent = rowCounter;
  }
}

function collectRows() {
  var rows = document.getElementById('table-body').querySelectorAll('tr');
  var entries = [];
  for (var i = 0; i < rows.length; i++) {
    var keyInput = rows[i].querySelector('.key-input');
    var key = keyInput ? keyInput.value.trim() : '';
    if (!key) continue;
    var translations = {};
    for (var j = 0; j < LANGUAGES.length; j++) {
      var langInput = rows[i].querySelector('.lang-' + LANGUAGES[j].replace(/-/g, '_'));
      if (langInput && langInput.value.trim()) {
        translations[LANGUAGES[j]] = langInput.value.trim();
      }
    }
    entries.push({ key: key, translations: translations });
  }
  return entries;
}

function saveToStorage() {
  var entries = collectRows();
  var data = { namespaceId: getNamespaceId(), rows: entries };
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  } catch (_) {}
}

function loadFromStorage() {
  try {
    var raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return false;
    var data = JSON.parse(raw);
    if (!data.rows || !data.rows.length) return false;

    // Restore namespace if it matches
    if (data.namespaceId) {
      var sel = document.getElementById('ns-select');
      for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value === data.namespaceId) {
          sel.value = data.namespaceId;
          break;
        }
      }
    }

    var body = document.getElementById('table-body');
    for (var i = 0; i < data.rows.length; i++) {
      var row = data.rows[i];
      var tr = createRow();
      body.appendChild(tr);
      tr.querySelector('.key-input').value = row.key || '';
      if (row.translations) {
        for (var lang in row.translations) {
          var input = tr.querySelector('.lang-' + lang.replace(/-/g, '_'));
          if (input) input.value = row.translations[lang] || '';
        }
      }
    }
    return true;
  } catch (_) {
    return false;
  }
}

function clearStorage() {
  try {
    localStorage.removeItem(STORAGE_KEY);
  } catch (_) {}
}

function updateSaveButton() {
  var entries = collectRows();
  var btn = document.getElementById('save-btn');
  if (entries.length > 0) {
    btn.disabled = false;
    btn.textContent = 'Save ' + entries.length + ' translation' + (entries.length !== 1 ? 's' : '');
  } else {
    btn.disabled = true;
    btn.textContent = 'Save Translations';
  }
}

function onInput(e) {
  saveToStorage();
  updateSaveButton();

  // Auto-expand: if typing in the last row's key field, add more rows
  if (e.target.classList.contains('key-input')) {
    var body = document.getElementById('table-body');
    var rows = body.querySelectorAll('tr');
    var lastRow = rows[rows.length - 1];
    if (lastRow && lastRow.contains(e.target) && e.target.value.trim()) {
      addRows(10);
    }
  }
}

function onKeyBlur(e) {
  var key = e.target.value.trim();
  var errorDiv = e.target.parentElement.querySelector('.key-error');
  if (!key) {
    e.target.classList.remove('border-red-500');
    if (errorDiv) errorDiv.innerHTML = '';
    return;
  }

  var nsId = getNamespaceId();
  fetch('/projects/' + PROJECT_ID + '/add-translations/check-key?key=' + encodeURIComponent(key) + '&namespace_id=' + encodeURIComponent(nsId))
    .then(function(res) { return res.text(); })
    .then(function(html) {
      if (html && html.trim()) {
        e.target.classList.add('border-red-500');
        if (errorDiv) errorDiv.innerHTML = html;
      } else {
        e.target.classList.remove('border-red-500');
        if (errorDiv) errorDiv.innerHTML = '';
      }
    })
    .catch(function() {});
}

function showStatus(msg, isError) {
  var area = document.getElementById('status-area');
  area.classList.remove('hidden', 'bg-green-900/20', 'border-green-500/30', 'text-green-400', 'bg-red-900/20', 'border-red-500/30', 'text-red-400');
  if (isError) {
    area.className = 'mb-4 p-3 rounded-lg text-sm flex items-center justify-between bg-red-900/20 border border-red-500/30 text-red-400';
  } else {
    area.className = 'mb-4 p-3 rounded-lg text-sm flex items-center justify-between bg-green-900/20 border border-green-500/30 text-green-400';
  }
  area.textContent = msg;
}

function saveTranslations() {
  var entries = collectRows();
  if (entries.length === 0) return;

  var btn = document.getElementById('save-btn');
  btn.disabled = true;
  btn.textContent = 'Saving...';

  var payload = {
    namespace_id: getNamespaceId(),
    entries: entries
  };

  var csrfMeta = document.querySelector('meta[name="csrf-token"]');
  var headers = { 'Content-Type': 'application/json' };
  if (csrfMeta) headers['x-csrf-token'] = csrfMeta.content;

  fetch('/projects/' + PROJECT_ID + '/add-translations', {
    method: 'POST',
    headers: headers,
    body: JSON.stringify(payload)
  })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    if (data.ok) {
      clearStorage();
      window.location.href = '/projects/' + PROJECT_ID + '/editor?namespace=' + getNamespaceId() + '&imported=' + data.count;
    } else {
      showStatus(data.error || 'Failed to save translations', true);
      updateSaveButton();
    }
  })
  .catch(function(err) {
    showStatus('Network error: ' + err.message, true);
    updateSaveButton();
  });
}

function clearAll() {
  if (!confirm('Clear all rows and stored data?')) return;
  clearStorage();
  document.getElementById('table-body').innerHTML = '';
  rowCounter = 0;
  addRows(10);
  updateSaveButton();
  var area = document.getElementById('status-area');
  area.classList.add('hidden');
}

// Namespace change
document.getElementById('ns-select').addEventListener('change', function() {
  saveToStorage();
});

// Init
(function() {
  var restored = loadFromStorage();
  if (!restored) {
    addRows(10);
  }
  // Always ensure at least 10 rows visible
  var currentRows = document.getElementById('table-body').querySelectorAll('tr').length;
  if (currentRows < 10) {
    addRows(10 - currentRows);
  }
  updateSaveButton();
})();
</script>
{% endblock %}
