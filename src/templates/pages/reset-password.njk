{# reset-password.njk — standalone page, no sidebar layout #}
<!DOCTYPE html>
<html lang="en" class="dark notranslate" translate="no">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Reset Password — Parlats</title>
  <link rel="icon" href="/public/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/public/favicon-32x32.png" sizes="32x32" type="image/png">
  <link rel="icon" href="/public/favicon-16x16.png" sizes="16x16" type="image/png">
  <link rel="apple-touch-icon" href="/public/apple-touch-icon.png">
  <link rel="manifest" href="/public/site.webmanifest">
  <meta name="theme-color" content="#6366f1">
  <meta name="robots" content="noindex">
  <link rel="stylesheet" href="/public/tailwind.css">
</head>
<body class="flex items-center justify-center min-h-screen bg-surface text-text-primary">
  <div class="w-full max-w-sm mx-4">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold flex items-center justify-center gap-2">
        <img src="/public/favicon.svg" alt="" style="width:1.75rem;height:1.75rem" class="w-7 h-7 rounded"> Parlats
      </h1>
    </div>

    <div class="bg-surface-card border border-border rounded-lg p-6">
      {% if error == "missing_token" or error == "invalid_token" %}
        <div class="mb-4 p-3 rounded bg-danger/10 border border-danger/30 text-sm text-danger">
          This reset link is invalid or has expired.
        </div>
        <div class="text-center">
          <a href="/auth/forgot-password" class="text-sm text-primary hover:underline">Request a new reset link</a>
        </div>

      {% elif error == "password_too_short" %}
        <div class="mb-4 p-3 rounded bg-danger/10 border border-danger/30 text-sm text-danger">
          Password must be at least 8 characters.
        </div>
        {% include "pages/_reset-password-form.njk" %}

      {% elif error == "password_mismatch" %}
        <div class="mb-4 p-3 rounded bg-danger/10 border border-danger/30 text-sm text-danger">
          Passwords do not match.
        </div>
        {% include "pages/_reset-password-form.njk" %}

      {% else %}
        <h2 class="text-lg font-semibold text-center mb-4">Set a new password</h2>
        {% include "pages/_reset-password-form.njk" %}
      {% endif %}
    </div>
  </div>
</body>
</html>
