{% extends "base.njk" %}

{% block title %}Notification Settings — Parlats{% endblock %}

{% block content %}
<div class="mb-6">
  <h1 class="text-2xl font-bold mb-1">{{ t("notifications.settings_title") }}</h1>
  <p class="text-text-muted text-sm">{{ t("notifications.settings_subtitle") }}</p>
</div>

{% if error %}
<div class="mb-4 px-4 py-3 rounded bg-danger/10 border border-danger/20 text-danger text-sm">
  {{ error }}
</div>
{% endif %}

{% if success %}
<div class="mb-4 px-4 py-3 rounded bg-success/10 border border-success/20 text-success text-sm">
  {{ success }}
</div>
{% endif %}

<form method="post" action="/org/notifications" class="max-w-lg space-y-6">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
  <div class="bg-surface-card border border-border rounded-lg p-6 space-y-5">
    <h2 class="text-lg font-semibold">{{ t("notifications.threshold_alerts") }}</h2>

    <div>
      <label class="block text-sm font-medium text-text-secondary mb-1" for="untranslated_threshold">
        {{ t("notifications.untranslated_threshold_label") }}
      </label>
      <input type="number" id="untranslated_threshold" name="untranslated_threshold"
             value="{{ config.untranslated_threshold }}" min="1" max="10000"
             class="w-full bg-surface border border-border rounded px-3 py-2 text-sm text-text-primary focus:border-primary focus:outline-none">
      <p class="text-xs text-text-muted mt-1">{{ t("notifications.untranslated_threshold_help") }}</p>
    </div>

    <div>
      <label class="block text-sm font-medium text-text-secondary mb-1" for="email_cooldown_hours">
        {{ t("notifications.email_cooldown_label") }}
      </label>
      <select id="email_cooldown_hours" name="email_cooldown_hours"
              class="w-full bg-surface border border-border rounded px-3 py-2 text-sm text-text-primary focus:border-primary focus:outline-none">
        <option value="12" {% if config.email_cooldown_hours == 12 %}selected{% endif %}>{{ t("notifications.cooldown_12h") }}</option>
        <option value="24" {% if config.email_cooldown_hours == 24 %}selected{% endif %}>{{ t("notifications.cooldown_24h") }}</option>
        <option value="48" {% if config.email_cooldown_hours == 48 %}selected{% endif %}>{{ t("notifications.cooldown_48h") }}</option>
        <option value="168" {% if config.email_cooldown_hours == 168 %}selected{% endif %}>{{ t("notifications.cooldown_7d") }}</option>
      </select>
      <p class="text-xs text-text-muted mt-1">{{ t("notifications.email_cooldown_help") }}</p>
    </div>
  </div>

  <div class="bg-surface-card border border-border rounded-lg p-6 space-y-5">
    <h2 class="text-lg font-semibold">{{ t("notifications.notification_types") }}</h2>

    <label class="flex items-center gap-3 cursor-pointer">
      <input type="checkbox" name="overwrite_notifications" {% if config.overwrite_notifications %}checked{% endif %}
             class="w-4 h-4 rounded border-border text-primary focus:ring-primary">
      <div>
        <div class="text-sm font-medium text-text-primary">{{ t("notifications.overwrite_title") }}</div>
        <div class="text-xs text-text-muted">{{ t("notifications.overwrite_description") }}</div>
      </div>
    </label>

    <label class="flex items-center gap-3 cursor-pointer">
      <input type="checkbox" name="comment_notifications" {% if config.comment_notifications %}checked{% endif %}
             class="w-4 h-4 rounded border-border text-primary focus:ring-primary">
      <div>
        <div class="text-sm font-medium text-text-primary">{{ t("notifications.comment_title") }}</div>
        <div class="text-xs text-text-muted">{{ t("notifications.comment_description") }}</div>
      </div>
    </label>
  </div>

  <button type="submit"
          class="px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded font-medium text-sm cursor-pointer border-0">
    {{ t("notifications.save_settings") }}
  </button>
</form>
{% endblock %}
