{# emails/invitation.njk — team invitation #}
{% extends "emails/layout.njk" %}

{% block title %}Join {{ orgName }} on Parlats{% endblock %}

{% block content %}
<h1 style="margin:0 0 8px;font-size:22px;font-weight:700;color:#1a1a2e;">You're invited!</h1>
<p style="margin:0 0 24px;font-size:15px;color:#6b7280;line-height:1.5;">
  <strong style="color:#1a1a2e;">{{ inviterName }}</strong> invited you to join
  <strong style="color:#6366f1;">{{ orgName }}</strong> as <strong style="color:#1a1a2e;">{{ role }}</strong>.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto 24px;">
  <tr>
    <td align="center" style="background-color:#6366f1;border-radius:8px;">
      <a href="{{ acceptLink }}"
         style="display:inline-block;padding:12px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:8px;">
        Accept invitation
      </a>
    </td>
  </tr>
</table>

<p style="margin:0 0 4px;font-size:13px;color:#9ca3af;line-height:1.5;">
  This invitation expires in 7 days. If you weren't expecting this, you can safely ignore it.
</p>
{% endblock %}
