{# emails/verify-email.njk — email verification #}
{% extends "emails/layout.njk" %}

{% block title %}Verify your email — Parlats{% endblock %}

{% block content %}
<h1 style="margin:0 0 8px;font-size:22px;font-weight:700;color:#1a1a2e;">Verify your email</h1>
<p style="margin:0 0 24px;font-size:15px;color:#6b7280;line-height:1.5;">
  Tap the button below to confirm your email address and finish setting up your account.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto 24px;">
  <tr>
    <td align="center" style="background-color:#6366f1;border-radius:8px;">
      <a href="{{ verifyLink }}"
         style="display:inline-block;padding:12px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:8px;">
        Verify email address
      </a>
    </td>
  </tr>
</table>

<p style="margin:0 0 4px;font-size:13px;color:#9ca3af;line-height:1.5;">
  This link expires in 24 hours. If you didn't create a Parlats account, you can safely ignore this email.
</p>
{% endblock %}
