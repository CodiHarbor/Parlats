{# Empty state with icon, message, and optional action #}
{% macro empty_state(title, message, action_url="", action_text="") %}
<div class="text-center py-12 px-4">
  <h3 class="text-lg font-semibold text-text-primary mb-2">{{ title }}</h3>
  <p class="text-text-muted mb-4">{{ message }}</p>
  {% if action_url %}
  <a href="{{ action_url }}"
     class="inline-block px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded font-medium text-sm no-underline">
    {{ action_text }}
  </a>
  {% endif %}
</div>
{% endmacro %}

{# Modal dialog — usage: {% call modal("my-modal", "Title") %}content{% endcall %} #}
{# Optional maxWidth: "max-w-lg" (default), "max-w-2xl", "max-w-4xl", etc. #}
{% macro modal(id, title, maxWidth="max-w-lg") %}
<dialog id="{{ id }}" role="dialog" aria-modal="true" aria-labelledby="{{ id }}-title"
  class="fixed inset-0 z-50 m-auto w-full {{ maxWidth }} bg-surface-card border border-border rounded-lg shadow-xl p-0 backdrop:bg-black/50"
  onclick="if(event.target===this)this.close()">
  <div class="flex items-center justify-between px-5 py-4 border-b border-border">
    <h2 id="{{ id }}-title" class="text-lg font-semibold text-text-primary m-0">{{ title }}</h2>
    <button type="button" aria-label="Close"
      class="text-text-muted hover:text-text-primary bg-transparent border-0 text-lg cursor-pointer p-1"
      onclick="this.closest('dialog').close()"><svg class="w-5 h-5" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18L18 6M6 6l12 12"/></svg></button>
  </div>
  <div class="px-5 py-4">
    {{ caller() }}
  </div>
</dialog>
{% endmacro %}

{# Breadcrumb navigation #}
{% macro breadcrumbs(items) %}
<nav aria-label="Breadcrumb" class="mb-4">
  <ol class="flex items-center gap-1 text-sm list-none p-0 m-0">
    {% for item in items %}
    <li class="flex items-center gap-1">
      {% if not loop.first %}<span class="text-text-muted">/</span>{% endif %}
      {% if item.url %}
        <a href="{{ item.url }}" class="text-text-secondary hover:text-primary no-underline">{{ item.label }}</a>
      {% else %}
        <span class="text-text-muted">{{ item.label }}</span>
      {% endif %}
    </li>
    {% endfor %}
  </ol>
</nav>
{% endmacro %}
