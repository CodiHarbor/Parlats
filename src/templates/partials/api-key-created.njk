{% if error %}
  <div class="p-4 bg-red-500/10 border border-red-500/20 rounded-lg text-red-400 text-sm">
    {{ error }}
  </div>
{% else %}
  <div class="p-5 space-y-4">
    <div class="flex items-center gap-2 text-green-400">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      <span class="font-medium">{{ t("api.key_created_success") }}</span>
    </div>

    <div class="bg-surface-bg border border-border rounded-lg p-4">
      <p class="text-xs text-text-secondary mb-2">{{ t("api.key_created_copy_note") }}</p>
      <div class="flex items-center gap-2">
        <code class="flex-1 text-sm font-mono text-text-primary bg-black/20 px-3 py-2 rounded break-all" id="api-key-value">{{ fullKey }}</code>
        <button
          type="button"
          onclick="navigator.clipboard.writeText(document.getElementById('api-key-value').textContent); this.textContent='{{ t("common.copied") }}'; setTimeout(() => this.textContent='{{ t("common.copy") }}', 2000)"
          class="px-3 py-2 text-xs bg-primary hover:bg-primary-hover text-white rounded whitespace-nowrap cursor-pointer border-0"
        >{{ t("common.copy") }}</button>
      </div>
    </div>

    <p class="text-xs text-text-secondary">
      {{ t("api.key_created_name_note", { name: name }) }}
    </p>

    <div class="flex justify-end">
      <button
        type="button"
        onclick="this.closest('dialog').close(); window.location.reload()"
        class="px-4 py-2 text-sm bg-surface-card border border-border rounded-lg hover:bg-surface-hover text-text-primary cursor-pointer"
      >{{ t("common.done") }}</button>
    </div>
  </div>
{% endif %}
