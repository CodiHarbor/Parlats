{% from "macros/icons.njk" import icon %}
<div class="flex items-center justify-between px-4 py-3 border-b border-border">
  <div class="flex items-center gap-2">
    <span class="font-semibold text-sm text-text-primary">{{ t("comments.title") }}</span>
    <span class="inline-block px-2 py-0.5 bg-primary/10 text-primary text-xs rounded font-mono">{{ keyName }}</span>
  </div>
  <button type="button"
    class="text-text-muted hover:text-text-primary bg-transparent border-0 text-sm cursor-pointer p-1"
    onclick="document.getElementById('comment-panel').classList.add('hidden')">{{ icon("x", "w-4 h-4") }}</button>
</div>

<div class="flex-1 overflow-y-auto px-4 py-3 space-y-4">
  {% if comments.length == 0 %}
  <p class="text-text-muted text-sm text-center py-6">{{ t("comments.no_comments") }}</p>
  {% endif %}

  {% for c in comments %}
  <div class="group" id="comment-{{ c.id }}">
    <div class="flex items-start gap-3">
      <span class="w-8 h-8 shrink-0 rounded-full bg-primary text-white text-xs font-bold flex items-center justify-center">
        {{ (c.user_name or c.user_email)[0] | upper }}
      </span>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold text-text-primary">{{ c.user_name or c.user_email }}</span>
          <span class="text-xs text-text-muted">{{ c.created_at | timeago }}</span>
          {% if c.language_code %}
          <span class="inline-block px-1.5 py-0.5 bg-primary/10 text-primary text-xs rounded">{{ c.language_code }}</span>
          {% endif %}
          {% if c.user_id == ctx.user.id or ctx.org.role == 'admin' or ctx.org.role == 'owner' %}
          <button type="button"
            hx-post="/projects/{{ project.id }}/keys/{{ keyId }}/comments/{{ c.id }}/delete"
            hx-target="#comment-{{ c.id }}"
            hx-swap="outerHTML"
            hx-confirm="{{ t("comments.delete_confirm") }}"
            class="ml-auto text-text-muted hover:text-danger bg-transparent border-0 cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity">{{ icon("x", "w-3.5 h-3.5") }}</button>
          {% endif %}
        </div>
        <p class="text-sm text-text-secondary mt-1 whitespace-pre-wrap">{{ c.body }}</p>
      </div>
    </div>
    {% if not loop.last %}
    <hr class="border-border mt-4">
    {% endif %}
  </div>
  {% endfor %}
</div>

<div class="border-t border-border px-4 py-3">
  <form hx-post="/projects/{{ project.id }}/keys/{{ keyId }}/comments"
        hx-target="#comment-panel-content"
        hx-swap="innerHTML"
        class="flex gap-2">
    <input type="hidden" name="language_code" value="{{ lang }}">
    <textarea name="body" rows="2" placeholder="{{ t("comments.placeholder") }}"
      class="flex-1 bg-surface border border-border rounded px-3 py-2 text-sm text-text-primary placeholder-text-muted focus:outline-none focus:border-primary resize-none"
      onkeydown="if(event.key==='Enter'&&(event.ctrlKey||event.metaKey)){event.preventDefault();this.closest('form').requestSubmit()}"></textarea>
    <button type="submit"
      class="px-3 py-2 bg-primary hover:bg-primary-hover text-white rounded text-sm font-medium cursor-pointer self-end">{{ t("common.send") }}</button>
  </form>
</div>
